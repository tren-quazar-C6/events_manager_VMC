@model sporting.Models.Event


<div class="card detail-card">
    <div class="detail-header">
        <h3><i class="fas fa-trophy me-2" style="color:var(--g3)"></i>@Model.Name</h3>
    </div>
    <div class="detail-body">

        <div class="info-row">
            <div class="info-icon"><i class="fas fa-align-left"></i></div>
            <div>
                <div class="info-label">Description</div>
                <div class="info-value">@Model.Description</div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-icon"><i class="fas fa-medal"></i></div>
            <div>
                <div class="info-label">Sport</div>
                <div class="info-value">@Model.SportType</div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div>
                <div class="info-label">Venue</div>
                <div class="info-value">@Model.Venue</div>
            </div>
        </div>

        <div class="mt-4">
            <a asp-action="Index" asp-controller="Event" class="btn btn-outline-secondary btn-back">
                <i class="fas fa-arrow-left me-1"></i>Go back
            </a>
        </div>
    </div>
</div>