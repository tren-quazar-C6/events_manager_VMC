@model sporting.Models.Event

<div class="row">
    <div class="col-md-4 offset-md-4">
        <div class="card form-card">
            <div class="form-card-header">
                <h4><i class="fas fa-plus-circle me-2" style="color:var(--g3)"></i>New Event</h4>
                <p>Fill in the details to register a sporting event</p>
            </div>
            <div class="form-card-body">
                <form asp-action="Create" asp-controller="Event" method="post">

                    <div class="mt-4">
                        <label asp-for="Name" class="form-label">Event name</label>
                        <input asp-for="Name" class="form-control" type="text" placeholder="World Championship">
                    </div>

                    <div class="mt-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" type="text" class="form-control" placeholder="Event details..."></textarea>
                    </div>

                    <div class="mt-4">
                        <label asp-for="SportType" class="form-label">Sport</label>
                        <select asp-for="SportType" class="form-control">
                            <option selected disabled>Select a sport</option>
                            <option value="Swimming">Swimming</option>
                            <option value="Running">Running</option>
                            <option value="Football">Football</option>
                            <option value="Basketball">Basketball</option>
                        </select>
                    </div>

                    <div class="mt-4">
                        <label asp-for="Venue" class="form-label">Venue</label>
                        <input asp-for="Venue" type="text" class="form-control" placeholder="Aquatic Complex">
                    </div>

                    <div class="mt-4">
                        <label asp-for="StartDate" class="form-label">Start date</label>
                        <input asp-for="StartDate" type="date" class="form-control">
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Index" asp-controller="Event" class="btn btn-outline-secondary btn-cancel">Cancel</a>
                        <button class="btn btn-submit">
                            <i class="fas fa-save me-1"></i>Send
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>