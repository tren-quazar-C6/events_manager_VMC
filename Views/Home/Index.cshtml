@{
    ViewData["Title"] = "Home";
}

<!-- ══ HERO ══ -->
<div class="hero">
    <div class="hero-eyebrow"><i class="fas fa-trophy"></i> World-Class Sporting Events</div>
    <h1>Where Every Game<br>Becomes a <span>Legend</span></h1>
    <p>Explore, discover and stay up to date with the best sporting events across football, basketball, swimming, running and more.</p>
    <div>
        <a asp-controller="Event" asp-action="Gallery" class="hero-cta">
            <i class="fas fa-th-large"></i> Browse Events
        </a>
        <a asp-controller="Event" asp-action="Index" class="hero-cta-secondary">
            <i class="fas fa-shield-alt"></i> Admin Panel
        </a>
    </div>
    <div class="hero-sports-row">
        <span class="hero-sport-chip">
            <i class="fas fa-futbol"></i> Football
        </span>

        <span class="hero-sport-chip">
            <i class="fas fa-basketball-ball"></i> Basketball
        </span>

        <span class="hero-sport-chip">
            <i class="fas fa-swimmer"></i> Swimming
        </span>

        <span class="hero-sport-chip">
            <i class="fas fa-running"></i> Running
        </span>
    </div>
</div>

<!-- ══ STATS ══ -->
<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-number">4+</div>
            <div class="stat-label">Sports</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-globe"></i></div>
            <div class="stat-number">
                <i class="fas fa-globe"></i>
            </div>
            <div class="stat-label">Worldwide</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-bolt"></i></div>
            <div class="stat-number">Live</div>
            <div class="stat-label">Updates</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-shield-alt"></i></div>
            <div class="stat-number">100%</div>
            <div class="stat-label">Managed</div>
        </div>
    </div>
</div>

<!-- ══ SPORTS ══ -->
<p class="section-title">Explore by Sport</p>
<p class="section-sub">Click a sport to filter events in the gallery</p>
<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-football d-block">
            <div class="sport-card-bg">
                <i class="fas fa-futbol fa-2x"></i>
            </div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Football<small>The beautiful game</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-basketball d-block">
            <div class="sport-card-bg">
                <i class="fas fa-basketball-ball fa-2x"></i>
            </div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Basketball<small>Rise and dominate</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-swimming d-block">
            <div class="sport-card-bg">
                <i class="fas fa-swimmer fa-2x"></i>
            </div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Swimming<small>Speed through water</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-running d-block">
            <div class="sport-card-bg">
                <i class="fas fa-running fa-2x"></i>
            </div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Running<small>Push past the limit</small></div>
        </a>
    </div>
</div>

<!-- ══ HOW IT WORKS ══ -->
<div class="steps-section">
    <p class="section-title text-center">How It Works</p>
    <p class="section-sub text-center">Managing and discovering events has never been easier</p>
    <div class="row g-3 mt-1">
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">1</div>
                <div class="step-title">Browse Gallery</div>
                <div class="step-desc">Explore all sporting events in our public grid view</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">2</div>
                <div class="step-title">Filter by Sport</div>
                <div class="step-desc">Quickly find events that match your interest</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">3</div>
                <div class="step-title">View Details</div>
                <div class="step-desc">See full info about venue, date and description</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">4</div>
                <div class="step-title">Manage Events</div>
                <div class="step-desc">Use the Admin Panel to create, edit or delete</div>
            </div>
        </div>
    </div>
</div>

<!-- ══ CTA FINAL ══ -->
<div class="cta-section">
    <i class="fas fa-trophy fa-2x mb-3" style="color:var(--g5)"></i>
    <h2>Ready to Add Your Event?</h2>
    <p>Use the admin panel to register new sporting events and share them with the world.</p>
    <a asp-controller="Event" asp-action="Create" class="hero-cta">
        <i class="fas fa-plus"></i> Create New Event
    </a>
</div>