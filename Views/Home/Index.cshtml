@{
    ViewData["Title"] = "Home";
}

<style>
    :root { --g1:#485E5C; --g2:#90BFB3; --g3:#C5FFDD; --g4:#BBE0AD; --g5:#6DC2B8; }

    /* ── HERO ── */
    .hero {
        background: linear-gradient(135deg, #2e3f3d 0%, var(--g1) 60%, #3a5250 100%);
        border-radius: 24px;
        padding: 4rem 3rem;
        color: white;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 260px; height: 260px;
        border-radius: 50%;
        background: rgba(197,255,221,0.07);
    }
    .hero::after {
        content: '';
        position: absolute;
        bottom: -80px; left: 25%;
        width: 320px; height: 320px;
        border-radius: 50%;
        background: rgba(109,194,184,0.06);
    }
    .hero-eyebrow {
        display: inline-block;
        background: rgba(197,255,221,0.15);
        border: 1px solid rgba(197,255,221,0.3);
        color: var(--g3);
        border-radius: 20px;
        padding: 0.3rem 1rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 1.2rem;
    }
    .hero h1 {
        font-size: 2.8rem;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }
    .hero h1 span { color: var(--g3); }
    .hero p {
        color: rgba(255,255,255,0.65);
        font-size: 1.05rem;
        max-width: 520px;
        margin-bottom: 2rem;
    }
    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--g3);
        color: var(--g1);
        font-weight: 800;
        border-radius: 12px;
        padding: 0.75rem 1.8rem;
        text-decoration: none;
        font-size: 0.95rem;
        transition: opacity 0.2s;
        margin-right: 0.75rem;
    }
    .hero-cta:hover { opacity: 0.85; color: var(--g1); }
    .hero-cta-secondary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        color: rgba(255,255,255,0.8);
        font-weight: 600;
        border: 2px solid rgba(255,255,255,0.25);
        border-radius: 12px;
        padding: 0.75rem 1.6rem;
        text-decoration: none;
        font-size: 0.95rem;
        transition: all 0.2s;
    }
    .hero-cta-secondary:hover {
        border-color: var(--g3);
        color: var(--g3);
    }
    .hero-sports-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 2.5rem;
    }
    .hero-sport-chip {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 20px;
        padding: 0.3rem 0.9rem;
        font-size: 0.82rem;
        color: rgba(255,255,255,0.75);
    }

    /* ── STATS ── */
    .stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        box-shadow: 0 4px 18px rgba(72,94,91,0.08);
        border: none;
        transition: transform 0.2s;
    }
    .stat-card:hover { transform: translateY(-4px); }
    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        background: #edf7f4;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin: 0 auto 0.75rem;
        color: var(--g5);
    }
    .stat-number {
        font-size: 2rem;
        font-weight: 900;
        color: var(--g1);
        line-height: 1;
    }
    .stat-label {
        font-size: 0.78rem;
        color: #aaa;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-top: 0.3rem;
    }

    /* ── SPORTS SECTION ── */
    .section-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--g1);
        margin-bottom: 0.3rem;
    }
    .section-sub {
        font-size: 0.88rem;
        color: #aaa;
        margin-bottom: 1.8rem;
    }
    .sport-card {
        border-radius: 16px;
        overflow: hidden;
        position: relative;
        height: 160px;
        display: flex;
        align-items: flex-end;
        cursor: pointer;
        transition: transform 0.25s;
        text-decoration: none;
    }
    .sport-card:hover { transform: scale(1.03); }
    .sport-card-bg {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 4.5rem;
    }
    .sport-card-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(72,94,91,0.85) 0%, transparent 60%);
    }
    .sport-card-label {
        position: relative;
        color: #fff;
        font-weight: 800;
        font-size: 0.95rem;
        padding: 1rem;
        letter-spacing: 1px;
        width: 100%;
    }
    .sport-card-label small {
        display: block;
        font-size: 0.72rem;
        font-weight: 400;
        color: rgba(255,255,255,0.6);
        letter-spacing: 0;
    }
    .bg-football   { background: linear-gradient(135deg, #2e4a3e, var(--g1)); }
    .bg-basketball { background: linear-gradient(135deg, #3a5a4a, var(--g5)); }
    .bg-swimming   { background: linear-gradient(135deg, #2a4a50, var(--g2)); }
    .bg-running    { background: linear-gradient(135deg, var(--g1), #4a6e5c); }

    /* ── HOW IT WORKS ── */
    .steps-section {
        background: linear-gradient(135deg, #2e3f3d, var(--g1));
        border-radius: 24px;
        padding: 3rem 2rem;
        color: white;
        margin: 3rem 0;
    }
    .steps-section .section-title { color: var(--g3); }
    .steps-section .section-sub   { color: rgba(255,255,255,0.55); }
    .step-item {
        text-align: center;
        padding: 1rem;
    }
    .step-number {
        width: 52px; height: 52px;
        border-radius: 50%;
        background: rgba(197,255,221,0.15);
        border: 2px solid rgba(197,255,221,0.35);
        color: var(--g3);
        font-size: 1.3rem;
        font-weight: 900;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem;
    }
    .step-title {
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        margin-bottom: 0.4rem;
    }
    .step-desc { font-size: 0.82rem; color: rgba(255,255,255,0.55); }

    /* ── CTA FINAL ── */
    .cta-section {
        background: #fff;
        border-radius: 20px;
        padding: 3rem 2rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(72,94,91,0.08);
        margin-bottom: 1rem;
    }
    .cta-section h2 { font-weight: 900; color: var(--g1); margin-bottom: 0.5rem; }
    .cta-section p  { color: #aaa; font-size: 0.95rem; margin-bottom: 1.5rem; }
</style>

<!-- ══ HERO ══ -->
<div class="hero">
    <div class="hero-eyebrow">🏆 World-Class Sporting Events</div>
    <h1>Where Every Game<br>Becomes a <span>Legend</span></h1>
    <p>Explore, discover and stay up to date with the best sporting events across football, basketball, swimming, running and more.</p>
    <div>
        <a asp-controller="Event" asp-action="Gallery" class="hero-cta">
            <i class="fas fa-th-large"></i> Browse Events
        </a>
        <a asp-controller="Event" asp-action="Index" class="hero-cta-secondary">
            <i class="fas fa-shield-alt"></i> Admin Panel
        </a>
    </div>
    <div class="hero-sports-row">
        <span class="hero-sport-chip">⚽ Football</span>
        <span class="hero-sport-chip">🏀 Basketball</span>
        <span class="hero-sport-chip">🏊 Swimming</span>
        <span class="hero-sport-chip">🏃 Running</span>
    </div>
</div>

<!-- ══ STATS ══ -->
<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-number">4+</div>
            <div class="stat-label">Sports</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-globe"></i></div>
            <div class="stat-number">🌎</div>
            <div class="stat-label">Worldwide</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-bolt"></i></div>
            <div class="stat-number">Live</div>
            <div class="stat-label">Updates</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-shield-alt"></i></div>
            <div class="stat-number">100%</div>
            <div class="stat-label">Managed</div>
        </div>
    </div>
</div>

<!-- ══ SPORTS ══ -->
<p class="section-title">Explore by Sport</p>
<p class="section-sub">Click a sport to filter events in the gallery</p>
<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-football d-block">
            <div class="sport-card-bg">⚽</div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Football<small>The beautiful game</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-basketball d-block">
            <div class="sport-card-bg">🏀</div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Basketball<small>Rise and dominate</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-swimming d-block">
            <div class="sport-card-bg">🏊</div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Swimming<small>Speed through water</small></div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Event" asp-action="Gallery" class="sport-card bg-running d-block">
            <div class="sport-card-bg">🏃</div>
            <div class="sport-card-overlay"></div>
            <div class="sport-card-label">Running<small>Push past the limit</small></div>
        </a>
    </div>
</div>

<!-- ══ HOW IT WORKS ══ -->
<div class="steps-section">
    <p class="section-title text-center">How It Works</p>
    <p class="section-sub text-center">Managing and discovering events has never been easier</p>
    <div class="row g-3 mt-1">
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">1</div>
                <div class="step-title">Browse Gallery</div>
                <div class="step-desc">Explore all sporting events in our public grid view</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">2</div>
                <div class="step-title">Filter by Sport</div>
                <div class="step-desc">Quickly find events that match your interest</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">3</div>
                <div class="step-title">View Details</div>
                <div class="step-desc">See full info about venue, date and description</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="step-item">
                <div class="step-number">4</div>
                <div class="step-title">Manage Events</div>
                <div class="step-desc">Use the Admin Panel to create, edit or delete</div>
            </div>
        </div>
    </div>
</div>

<!-- ══ CTA FINAL ══ -->
<div class="cta-section">
    <i class="fas fa-trophy fa-2x mb-3" style="color:var(--g5)"></i>
    <h2>Ready to Add Your Event?</h2>
    <p>Use the admin panel to register new sporting events and share them with the world.</p>
    <a asp-controller="Event" asp-action="Create" class="hero-cta">
        <i class="fas fa-plus"></i> Create New Event
    </a>
</div>