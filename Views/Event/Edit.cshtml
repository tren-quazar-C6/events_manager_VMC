@model sporting.Models.Event


<div class="row">
    <div class="col-md-4 offset-md-4">
        <div class="card form-card">
            <div class="form-card-header">
                <h4><i class="fas fa-pen me-2" style="color:var(--g3)"></i>Edit Event</h4>
                <p>Update the event information below</p>
            </div>
            <div class="form-card-body">
                <form asp-action="Update" asp-controller="Event" method="post">
                    <input type="hidden" asp-for="Id">

                    <div class="mt-4">
                        <label class="form-label">Event Name</label>
                        <input type="text" class="form-control" asp-for="Name">
                    </div>

                    <div class="mt-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" type="text" class="form-control"></textarea>
                    </div>

                    <div class="mt-4">
                        <label asp-for="SportType" class="form-label">Sport</label>
                        <select asp-for="SportType" class="form-control">
                            <option value="Swimming">Swimming</option>
                            <option value="Running">Running</option>
                            <option value="Football">Football</option>
                            <option value="Basketball">Basketball</option>
                        </select>
                    </div>

                    <div class="mt-4">
                        <label asp-for="StartDate" class="form-label">Start Date</label>
                        <input asp-for="StartDate" type="datetime" class="form-control">
                    </div>

                    <div class="mt-4">
                        <label asp-for="Venue" class="form-label">Venue</label>
                        <input asp-for="Venue" type="text" class="form-control">
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Index" asp-controller="Event" class="btn btn-outline-secondary btn-cancel">Cancel</a>
                        <button class="btn btn-submit">
                            <i class="fas fa-save me-1"></i>Update
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>